pipeline {
    agent {
        label 'AGENT-1'
    }

     options {
        // Timeout counter starts AFTER agent is allocated
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    environment {
        appVersion = ''
        Region = 'us-east-1'
        ACC_ID = '506572015597'
        PROJECT = 'roboshop'
        COMPONENT = 'catalogue'
    }
     parameters {
        string(name: 'appVersion', description: 'Image Version of the application')
        choice(name: 'deploy_to', choices: ['dev', 'qa', 'prod'], description: 'Pick the environment')
       
    }

    stages {

        stage('Debug Params') {
    steps {
        script {
            echo "appVersion = ${params.appVersion}"
            echo "deploy_to = ${params.deploy_to}"
        }
    }
}
        stage ('Deploy') {
            steps {
                script {
                    withAWS(credentials: 'aws-creds', region: 'us-east-1'){
                        sh """
                           aws sts get-caller-identity

                            aws eks list-clusters --region us-east-1

                            aws eks update-kubeconfig \
                            --region us-east-1 \
                            --name Roboshop-env
                            kubectl apply -f namespace.yaml
                            kubectl get nodes
                            sed -i "s/IMAGE_Version/${params.appVersion}/g" values-${params.deploy_to}.yaml
                            helm upgrade --install $COMPONENT  -f values-${params.deploy_to}.yaml -n $PROJECT .
                        
                        """
                    }
                }
            }
        }

        stage('Check Status') {
            steps {
                script{
                    def deploymentstatus = sh(returnStdout: true, script: "kubectl rollout status deployment/catalogue --request-timeout=30s -n $PROJECT || echo FAILED").trim()
                    if (deploymentstatus.contains("successfully rolled out")) {
                        echo "Deployment is success"
                        
                    } else {
                        sh """
                            helm rollback $COMPONENT -n $PROJECT
                            sleep 20
                        """
                        def rollbackstatus = sh(returnStdout: true, script: "kubectl rollout status deployment/catalogue --request-timeout=30s -n $PROJECT || echo FAILED").trim()
                        if (rollbackstatus.contains("successfully rolled out")) {
                            error "Deployment is Failure, Rollback Success"
                        }
                        else {
                            error "Deployment is Failure,Rollback Failure. Application is not running "
                        }
                    }
                }
            }
        }

       
    }
} 